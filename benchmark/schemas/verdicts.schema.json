{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Verdicts",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "claim_id",
      "truth_verdict",
      "audit_action",
      "evidence_ids",
      "confidence",
      "reason"
    ],
    "properties": {
      "claim_id": {
        "type": "string"
      },
      "truth_verdict": {
        "type": "string",
        "enum": [
          "supported",
          "partially_supported",
          "refuted",
          "not_enough_evidence",
          "conflicting_evidence",
          "not_publicly_verifiable",
          "not_a_factual_claim"
        ]
      },
      "audit_action": {
        "type": "string",
        "enum": [
          "keep",
          "cite",
          "hedge",
          "rewrite",
          "remove",
          "local_verify",
          "human_review",
          "ignore"
        ]
      },
      "evidence_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "reason": {
        "type": "string"
      }
    },
    "additionalProperties": true
  }
}
